APP_NAME=Multi-User RAG API
APP_VERSION=1.0.0

SECRET_KEY=change_this_to_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql://postgres:postgres@db:5432/ragdb

OPENAI_API_KEY=your_openai_api_key_here

VECTOR_DB_PATH=./chroma_db
STORAGE_PATH=./storage

# Ollama (local LLM fallback — used when OPENAI_API_KEY is not set)
# In Docker: OLLAMA_BASE_URL is overridden to http://ollama:11434 automatically
# For local dev: install Ollama from https://ollama.com and run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2